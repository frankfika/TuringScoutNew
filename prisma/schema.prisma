generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Source {
  id              String         @id @default(cuid())
  name            String
  sourceType      String
  urlOrQuery      String
  categoryHint    String?
  priority        String         @default("medium")
  frequency       String         @default("manual")
  fetchMethod     String         @default("manual")
  allowedUseNotes String?
  enabled         Boolean        @default(true)
  lastCheckedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  rawEvidence     RawEvidence[]
  jobRuns         SourceJobRun[]
}

model RawEvidence {
  id               String     @id @default(cuid())
  sourceId         String?
  source           Source?    @relation(fields: [sourceId], references: [id])
  sourceType       String
  sourceName       String?
  sourceUrl        String
  discoveredAt     DateTime   @default(now())
  fetchedAt        DateTime?
  rawTitle         String?
  rawTextExcerpt   String?
  rawContentRef    String?
  authorOrAccount  String?
  publishedAt      DateTime?
  linkedUrls       Json?
  language         String?
  fetchStatus      String     @default("success")
  checksum         String?
  reviewStatus     String     @default("pending")
  extractionStatus String     @default("pending")
  createdAt        DateTime   @default(now())
  evidence         Evidence[]

  @@index([sourceType])
  @@index([fetchStatus])
  @@index([checksum])
}

model Project {
  id                 String                   @id @default(cuid())
  slug               String                   @unique
  name               String
  tagline            String?
  summary            String?
  category           String?
  tags               Json?
  officialWebsiteUrl String?
  githubUrl          String?
  docsUrl            String?
  blogUrl            String?
  huggingFaceUrl     String?
  productHuntUrl     String?
  logoUrl            String?
  trustLabel         String                   @default("unverified")
  riskLabels         Json?
  status             String                   @default("draft")
  lastCheckedAt      DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  opportunities      Opportunity[]
  evidence           Evidence[]
  creatorContent     CreatorContent[]
  githubSnapshots    GithubMetricSnapshot[]
  acknowledgements   ProjectAcknowledgement[]
  projectClaims      ProjectClaim[]
  campaigns          Campaign[]
  reports            ProjectReport[]
  attributionEvents  AttributionEvent[]

  @@index([status])
  @@index([category])
}

model Opportunity {
  id                  String             @id @default(cuid())
  projectId           String
  project             Project            @relation(fields: [projectId], references: [id])
  slug                String             @unique
  title               String
  summary             String?
  opportunityType     String
  rewardType          String?
  rewardDescription   String?
  taskSteps           Json?
  estimatedMinutes    Int?
  difficulty          String?
  requiresLogin       Boolean            @default(false)
  requiresWallet      Boolean            @default(false)
  primaryCtaUrl       String
  primaryCtaLabel     String
  trustLabel          String             @default("ai_summary")
  riskLabels          Json?
  utilityLabels       Json?
  commercialLabel     String?
  sourceConfidence    Int?
  organicScore        Float?
  adminScoreOverride  Float?
  adminOverrideReason String?
  whyRanked           String?
  status              String             @default("draft")
  reviewReason        String?
  expiresAt           DateTime?
  lastCheckedAt       DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  evidence            Evidence[]
  creatorContent      CreatorContent[]
  outboundClicks      OutboundClick[]
  reviewItems         ReviewQueueItem[]
  savedBy             SavedOpportunity[]
  attributionEvents   AttributionEvent[]

  @@index([projectId])
  @@index([status])
  @@index([opportunityType])
  @@index([organicScore])
  @@index([expiresAt])
}

model Evidence {
  id            String       @id @default(cuid())
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  rawEvidenceId String?
  rawEvidence   RawEvidence? @relation(fields: [rawEvidenceId], references: [id])
  sourceType    String
  sourceUrl     String
  title         String?
  rawText       String?
  aiSummary     String?
  confidence    Int?
  fetchedAt     DateTime?
  submittedAt   DateTime?
  status        String       @default("active")
  createdAt     DateTime     @default(now())

  @@index([projectId])
  @@index([opportunityId])
  @@index([status])
}

model Submission {
  id                  String   @id @default(cuid())
  url                 String
  type                String
  note                String?
  contactEmail        String?
  socialHandle        String?
  contentUrl          String?
  publicCreditOptIn   Boolean  @default(false)
  submitterIpHash     String?
  userAgentHash       String?
  status              String   @default("received")
  linkedProjectId     String?
  linkedOpportunityId String?
  reviewReason        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([type])
}

model Creator {
  id                String                   @id @default(cuid())
  displayName       String
  handle            String?
  platform          String?
  profileUrl        String?
  avatarUrl         String?
  role              String?
  status            String                   @default("pending")
  qualityScore      Int?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  creatorContent    CreatorContent[]
  acknowledgements  ProjectAcknowledgement[]
  publicUsers       PublicUser[]
  proofSubmissions  ProofSubmission[]
  attributionEvents AttributionEvent[]
}

model CreatorContent {
  id                String                   @id @default(cuid())
  creatorId         String?
  creator           Creator?                 @relation(fields: [creatorId], references: [id])
  projectId         String?
  project           Project?                 @relation(fields: [projectId], references: [id])
  opportunityId     String?
  opportunity       Opportunity?             @relation(fields: [opportunityId], references: [id])
  contentUrl        String
  platform          String?
  contentType       String
  title             String?
  summary           String?
  contributionType  String
  publicCreditLabel String?
  qualityLabel      String?
  riskLabels        Json?
  isSponsored       Boolean                  @default(false)
  acknowledgements  ProjectAcknowledgement[]
  status            String                   @default("pending")
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([opportunityId])
}

model ScoreSnapshot {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  scoreType   String
  score       Float
  components  Json
  explanation String?
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
}

model OutboundClick {
  id            String       @id @default(cuid())
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  projectId     String?
  targetUrl     String
  ctaType       String?
  sourceModule  String?
  category      String?
  visitorIdHash String?
  sessionIdHash String?
  isSponsored   Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([opportunityId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  eventName     String
  opportunityId String?
  projectId     String?
  creatorId     String?
  sourceModule  String?
  targetUrl     String?
  ctaType       String?
  category      String?
  props         Json?
  visitorIdHash String?
  sessionIdHash String?
  createdAt     DateTime @default(now())

  @@index([eventName])
  @@index([createdAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("owner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReviewQueueItem {
  id            String       @id @default(cuid())
  entityType    String
  entityId      String
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  priority      String       @default("medium")
  reason        String
  status        String       @default("open")
  assignedTo    String?
  createdAt     DateTime     @default(now())
  resolvedAt    DateTime?

  @@index([entityType, entityId])
  @@index([status])
  @@index([priority])
}

model SourceJobRun {
  id                 String    @id @default(cuid())
  sourceId           String
  source             Source    @relation(fields: [sourceId], references: [id])
  jobType            String    @default("manual")
  status             String    @default("queued")
  startedAt          DateTime?
  finishedAt         DateTime?
  rawEvidenceCreated Int       @default(0)
  candidatesCreated  Int       @default(0)
  errorMessage       String?
  createdAt          DateTime  @default(now())

  @@index([sourceId])
  @@index([status])
}

model ProjectAcknowledgement {
  id                  String          @id @default(cuid())
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id])
  creatorContentId    String?
  creatorContent      CreatorContent? @relation(fields: [creatorContentId], references: [id])
  acknowledgementType String
  sourceUrl           String
  note                String?
  createdAt           DateTime        @default(now())
  creator             Creator?        @relation(fields: [creatorId], references: [id])
  creatorId           String?

  @@index([projectId])
}

model GithubMetricSnapshot {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  repoUrl      String
  stars        Int?
  forks        Int?
  watchers     Int?
  openIssues   Int?
  pullRequests Int?
  contributors Int?
  releases     Int?
  topics       Json?
  license      String?
  lastPushedAt DateTime?
  capturedAt   DateTime  @default(now())

  @@index([projectId])
}

model AutomationTask {
  id         String    @id @default(cuid())
  taskType   String
  status     String    @default("queued")
  priority   String    @default("medium")
  payload    Json?
  result     Json?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([taskType])
}

model DigestDraft {
  id        String   @id @default(cuid())
  period    String
  title     String
  body      String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationDraft {
  id         String   @id @default(cuid())
  targetType String
  targetId   String?
  channel    String   @default("email")
  subject    String
  body       String
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
}

model PublicUser {
  id                 String             @id @default(cuid())
  email              String             @unique
  displayName        String
  role               String             @default("scout")
  creatorId          String?
  creator            Creator?           @relation(fields: [creatorId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  savedOpportunities SavedOpportunity[]

  @@index([creatorId])
}

model SavedOpportunity {
  id            String      @id @default(cuid())
  userId        String
  user          PublicUser  @relation(fields: [userId], references: [id])
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  status        String      @default("saved")
  notes         String?
  proofUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, opportunityId])
  @@index([status])
}

model ProjectClaim {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  contactEmail String
  proofUrl     String?
  note         String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

model AttributionEvent {
  id            String       @id @default(cuid())
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  creatorId     String?
  creator       Creator?     @relation(fields: [creatorId], references: [id])
  campaignId    String?
  campaign      Campaign?    @relation(fields: [campaignId], references: [id])
  eventType     String
  source        String?
  value         Float?
  metadata      Json?
  createdAt     DateTime     @default(now())

  @@index([projectId])
  @@index([campaignId])
  @@index([eventType])
}

model Campaign {
  id                String             @id @default(cuid())
  projectId         String
  project           Project            @relation(fields: [projectId], references: [id])
  slug              String             @unique
  title             String
  campaignType      String
  brief             String
  rewardDescription String?
  eligibility       String?
  status            String             @default("draft")
  isSponsored       Boolean            @default(true)
  budgetLabel       String?
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tasks             CampaignTask[]
  proofSubmissions  ProofSubmission[]
  attributionEvents AttributionEvent[]

  @@index([projectId])
  @@index([status])
  @@index([campaignType])
}

model CampaignTask {
  id                String            @id @default(cuid())
  campaignId        String
  campaign          Campaign          @relation(fields: [campaignId], references: [id])
  title             String
  proofRequirements String
  status            String            @default("open")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  proofSubmissions  ProofSubmission[]

  @@index([campaignId])
  @@index([status])
}

model ProofSubmission {
  id           String        @id @default(cuid())
  campaignId   String?
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  taskId       String?
  task         CampaignTask? @relation(fields: [taskId], references: [id])
  creatorId    String?
  creator      Creator?      @relation(fields: [creatorId], references: [id])
  userEmail    String?
  proofUrl     String
  note         String?
  qualityLabel String?
  status       String        @default("pending")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([campaignId])
  @@index([status])
}

model ProjectReport {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  slug            String   @unique
  title           String
  summary         String
  metrics         Json
  recommendations Json?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  status     String    @default("active")
  scopes     Json?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([status])
}

model CategoryTrendSnapshot {
  id               String   @id @default(cuid())
  category         String
  snapshotDate     DateTime @default(now())
  opportunityCount Int
  averageScore     Float
  topProjects      Json
  riskMix          Json
  createdAt        DateTime @default(now())

  @@index([category])
  @@index([snapshotDate])
}
