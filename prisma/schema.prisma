generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Source {
  id         String   @id @default(uuid())
  name       String
  url        String
  type       String // SourceType
  tier       String // SourceTier
  enabled    Boolean  @default(true)
  schedule   String   @default("0 * * * *")
  lastRunAt  DateTime?
  lastStatus String @default("PENDING") // RunStatus
  config     String @default("{}")
  rawEvidences RawEvidence[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RawEvidence {
  id          String    @id @default(uuid())
  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id])
  url         String
  rawData     String
  fingerprint String
  status      String @default("PENDING") // EvidenceStatus
  collectedAt DateTime @default(now())
  extraction  Extraction?
}

model Extraction {
  id            String      @id @default(uuid())
  rawEvidenceId String      @unique
  rawEvidence   RawEvidence @relation(fields: [rawEvidenceId], references: [id])
  projectName   String?
  projectUrl    String?
  githubUrl     String?
  description   String?
  language      String?
  topics        String        @default("[]")
  category      String? // ProjectCategory
  suggestedType String? // OpportunityType
  extractedAt   DateTime    @default(now())
}

model Project {
  id                String    @id @default(uuid())
  slug              String    @unique
  name              String
  description       String?
  url               String
  githubUrl         String?
  language          String?
  topics            String      @default("[]")
  category          String? // ProjectCategory
  status            String @default("ACTIVE") // ProjectStatus
  firstSeenAt       DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  publishedAt       DateTime?
  opportunities     Opportunity[]
  evidences         Evidence[]
  scoreSnapshots    ScoreSnapshot[]
  aiReviews         AIReview[]
  communityPosts    CommunityPost[]
  agentCards        AgentCard[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Opportunity {
  id            String    @id @default(uuid())
  slug          String    @unique
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  title         String
  description   String?
  type          String // OpportunityType
  rewardValue   String?
  requirements  String?
  actionUrl     String
  expiresAt     DateTime?
  riskLevel     String @default("LOW") // RiskLevel
  autoPublished Boolean   @default(false)
  publishedAt   DateTime?
  status        String @default("CANDIDATE") // OpportunityStatus
  scoreSnapshots ScoreSnapshot[]
  aiReviews      AIReview[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Evidence {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  metric      String // MetricType
  value       Float
  recordedAt  DateTime  @default(now())

  @@index([projectId, recordedAt])
}

model ScoreSnapshot {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  totalScore    Float
  dimensions    String
  calculatedAt  DateTime @default(now())

  @@index([projectId, calculatedAt])
}

model AIReview {
  id            String   @id @default(uuid())
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  highlights    String // Json String
  suitableFor   String
  comparisons   String // Json String
  totalScore          Float
  dimensionScores     String // Json String
  generatedAt  DateTime @default(now())
  aiModel      String?
  adminEdited  Boolean   @default(false)
  adminNotes   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId, generatedAt])
  @@index([opportunityId, generatedAt])
}

model AdminSession {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── User Session (Blockchain Wallet Login) ────────────────────────────
model UserSession {
  id            String   @id @default(uuid())
  walletAddress String   // Unified wallet address (Solana/EVM/HTX)
  chain         String   // solana | evm | htx
  token         String   @unique // Session token
  nonce         String?  // For signature verification
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([walletAddress])
  @@index([chain])
}

model WalletNonce {
  id            String   @id @default(uuid())
  walletAddress String
  chain         String
  nonce         String   @unique
  message       String
  used          Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([walletAddress, chain])
  @@index([nonce])
}

model CommunityPost {
  id          String   @id @default(uuid())
  type        String   // "tweet" | "ai_summary"
  author      String?
  handle      String?
  avatar      String?
  content     String
  rating      String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  likes       Int      @default(0)
  retweets    Int      @default(0)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([publishedAt])
}

model TickerItem {
  id          String   @id @default(uuid())
  text        String
  link        String?
  priority    Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ── A2A Agent Card (Google A2A Protocol) ──────────────────────────────

model AgentCard {
  id            String    @id @default(uuid())
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  name          String
  description   String?
  version       String    @default("1.0.0")
  endpointUrl   String    // A2A endpoint URL
  avatarUrl     String?
  capabilities  String    @default("[]") // JSON: Skill[]
  authType      String    @default("none") // none | apiKey | oauth
  status        String    @default("ACTIVE") // ACTIVE | OFFLINE
  walletSolana  String?
  walletEvm     String?
  walletHtx     String?
  services      AgentService[]
  tasks         A2ATask[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([projectId])
}

model AgentService {
  id             String    @id @default(uuid())
  agentId        String
  agent          AgentCard @relation(fields: [agentId], references: [id])
  name           String
  description    String?
  inputModes     String    @default("[\"text\"]") // JSON string[]
  outputModes    String    @default("[\"text\"]") // JSON string[]
  priceUsd       Float     @default(0)
  acceptedChains String    @default("[\"solana\",\"evm\"]") // JSON string[]
  acceptedToken  String    @default("USDC")
  endpointPath   String    // relative path, e.g. "/analyze"
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([agentId])
  @@index([status])
}

model A2ATask {
  id          String    @id @default(uuid())
  agentId     String
  agent       AgentCard @relation(fields: [agentId], references: [id])
  status      String    @default("submitted") // submitted | working | completed | failed | canceled
  messages    String    @default("[]") // JSON: A2AMessage[]
  artifacts   String    @default("[]") // JSON: A2AArtifact[]
  paymentId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([agentId, status])
  @@index([createdAt])
}

// ── x402 Payment Layer ────────────────────────────────────────────────

model PaymentRequest {
  id            String   @id @default(uuid())
  taskId        String?
  payerAddress  String
  payeeAddress  String
  chain         String   // solana | evm | htx
  token         String   @default("USDC")
  amountUsd     Float
  amountToken   String?  // on-chain amount string (considering decimals)
  status        String   @default("PENDING") // PENDING | AUTHORIZED | CONFIRMED | FAILED | EXPIRED
  authorization String?  // signed authorization payload
  txHash        String?
  expiresAt     DateTime
  confirmedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([txHash])
  @@index([payerAddress])
}
