{
  "name": "turingscout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "test:smoke": "node scripts/smoke.mjs",
    "verify": "npm run lint && npm run build && npm run test:smoke && npm run audit:moderate",
    "audit:moderate": "npm_config_registry=https://registry.npmjs.org npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.20",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.5.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
